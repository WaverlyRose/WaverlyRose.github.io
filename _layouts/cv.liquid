---
layout: default
---
{% comment %}
  Local override of al_folio_core's cv.liquid.
  Adds scoped styling so CV dates render as a clean inline label
  (no filled pill / boxed lines) and locations read as muted text.
{% endcomment %}

<style>
  /* Dates: drop the filled pill + table borders for a seamless inline label */
  .cv .card .list-group-item .badge,
  .cv .card .list-group-item .badge.danger-color-dark {
    background-color: transparent !important;
    color: var(--global-theme-color) !important;
    padding: 0 !important;
    border: 0 !important;
    box-shadow: none !important;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none !important;
    white-space: nowrap;
  }

  /* Remove the table cell lines/background around the date + location */
  .cv .table-cv,
  .cv .table-cv tbody,
  .cv .table-cv tr,
  .cv .table-cv td {
    border: 0 !important;
    background-color: transparent !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  /* Make Experience/Education dates sit centered in their column like the
     Publications section, instead of the gem's narrowed, left-shifted box */
  .cv .date-column {
    width: auto;
    transform: none;
  }

  .cv .location {
    margin-top: 0.3rem;
    margin-bottom: 0;
    font-size: 0.78rem;
    line-height: 1.3;
    color: var(--global-text-color);
    opacity: 0.6;
  }

  .cv .iconlocation {
    margin-right: 0.3rem;
    opacity: 0.8;
  }

  /* Remove the bullet marker in front of each date/location entry.
     (Sub-point highlights keep their default bullets.) */
  .cv .card .list-group,
  .cv .card .list-group-flush {
    list-style: none;
    padding-left: 0;
    margin-left: 0;
  }

  .cv .card .list-group-item {
    list-style: none;
  }

  .cv .card .list-group-item::marker {
    content: "";
  }

  /* Breathing room between the "Projects" title and the first project */
  #projects + .card .card-title {
    margin-bottom: 1.25rem;
  }

  /* Add clear separation between entries in the Projects card */
  #projects + .card .list-group-item + .list-group-item {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--global-divider-color);
  }
</style>

{% assign cv_feature_enabled = site.al_folio.features.cv.enabled | default: true %}

{% if site.plugins contains 'al_folio_cv' and cv_feature_enabled %}
  {% al_folio_cv_render %}
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">CV rendering is unavailable.</p>
    </header>
    <article>
      <p>Enable the <code>al_folio_cv</code> plugin and set <code>al_folio.features.cv.enabled: true</code> to render this page.</p>
    </article>
  </div>
{% endif %}
